     loongarch_cpu_post_init(obj);
 }
 
+static void loongarch_la664_initfn(Object *obj)
+{
+    LoongArchCPU *cpu = LOONGARCH_CPU(obj);
+    CPULoongArchState *env = &cpu->env;
+    uint32_t data = 0;
+
+    /*
+     * Loongson 3A6000 / 3C6000 (LA664 core) is similar to LA464,
+     * so first initialize cpu data as la464, then update the special
+     * registers from real Loongson 3A6000 hardware (PRID 0x0014d000).
+     */
+    loongarch_la464_initfn(obj);
+
+    cpu->dtb_compatible = "loongarch,Loongson-3A6000";
+    memccpy((void *)&env->cpu_id, CPU_MODEL_3A6000, 0, 8);
+
+    /* PRID: Company=0x14 (Loongson), Series=0xd0 (LA664), Rev=0x00 */
+    data = 0;
+    data = FIELD_DP32(data, CPUCFG0, PRID, 0x00);
+    data = FIELD_DP32(data, CPUCFG0, SERID, PRID_SERIES_LA664);
+    data = FIELD_DP32(data, CPUCFG0, VENID, PRID_VENDOR_LOONGSON);
+    env->cpucfg[0] = data;
+
+    /* CPUCFG2: add LA664-specific features on top of LA464 base */
+    data = env->cpucfg[2];
+    data = FIELD_DP32(data, CPUCFG2, LVZ, 1);       /* LoongArch Virtualization */
+    data = FIELD_DP32(data, CPUCFG2, LVZ_VER, 1);
+    data = FIELD_DP32(data, CPUCFG2, LBT_X86, 1);   /* Binary Translation: x86 */
+    data = FIELD_DP32(data, CPUCFG2, LBT_ARM, 1);   /* Binary Translation: ARM */
+    data = FIELD_DP32(data, CPUCFG2, LBT_MIPS, 1);  /* Binary Translation: MIPS */
+    env->cpucfg[2] = data;
+
+    /* CPUCFG3: microarch features */
+    data = 0;
+    data = FIELD_DP32(data, CPUCFG3, CCDMA, 1);
+    data = FIELD_DP32(data, CPUCFG3, SFB, 1);
+    data = FIELD_DP32(data, CPUCFG3, UCACC, 1);
+    data = FIELD_DP32(data, CPUCFG3, LLEXC, 1);
+    data = FIELD_DP32(data, CPUCFG3, SCDLY, 1);
+    data = FIELD_DP32(data, CPUCFG3, LLDBAR, 1);
+    data = FIELD_DP32(data, CPUCFG3, ITLBHMC, 1);
+    data = FIELD_DP32(data, CPUCFG3, ICHMC, 1);
+    data = FIELD_DP32(data, CPUCFG3, SPW_LVL, 4);
+    data = FIELD_DP32(data, CPUCFG3, SPW_HP_HF, 1);
+    data = FIELD_DP32(data, CPUCFG3, RVA, 1);
+    data = FIELD_DP32(data, CPUCFG3, RVAMAX, 7);
+    env->cpucfg[3] = data;
+
+    /* CPUCFG6: performance monitor config */
+    data = 0;
+    data = FIELD_DP32(data, CPUCFG6, PMP, 1);
+    data = FIELD_DP32(data, CPUCFG6, PMVER, 1);
+    data = FIELD_DP32(data, CPUCFG6, PMNUM, 3);
+    data = FIELD_DP32(data, CPUCFG6, PMBITS, 63);
+    data = FIELD_DP32(data, CPUCFG6, UPM, 1);
+    env->cpucfg[6] = data;
+}
+
 static void loongarch_la132_initfn(Object *obj)
 {
     LoongArchCPU *cpu = LOONGARCH_CPU(obj);
