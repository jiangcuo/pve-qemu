+/*
+ * kvm_arm_gv8_get_host_isar - Read real host hardware ISAR values.
+ *
+ * The generic-v8 CPU model inherits A72's static ISAR values in initfn,
+ * but for KVM we need the actual host hardware values so that passthrough
+ * properties (sha3=on, sm3=on, etc.) can extract real feature bits.
+ *
+ * Uses the same kvm_arm_get_host_cpu_features() mechanism as -cpu host,
+ * which creates a temporary KVM VM/vcpu to read the host's ID registers.
+ * Results are cached so the temp VM is created at most once.
+ */
+bool kvm_arm_gv8_get_host_isar(uint64_t *isar0, uint64_t *isar1)
+{
+    if (!arm_host_cpu_features.dtb_compatible) {
+        if (!kvm_arm_get_host_cpu_features(&arm_host_cpu_features)) {
+            return false;
+        }
+    }
+    *isar0 = arm_host_cpu_features.isar.id_aa64isar0;
+    *isar1 = arm_host_cpu_features.isar.id_aa64isar1;
+    return true;
+}
+
+/*
+ * kvm_arm_gv8_apply_isar_filters - Write generic-v8 filtered ISAR values
+ * directly to KVM using kvm_set_one_reg.
+ *
+ * This follows the same pattern as kvm_arch_init_vcpu() which uses
+ * kvm_get_one_reg(ARM64_SYS_REG(...)) directly rather than going through
+ * the cpreg list mechanism.  Errors from kvm_set_one_reg are intentionally
+ * ignored: on kernels that do not support writable ID registers (< 5.13)
+ * the ioctl returns -EINVAL and the VM continues with host hardware values.
+ */
+void kvm_arm_gv8_apply_isar_filters(ARMCPU *cpu, uint64_t host_isar0,
+                                    uint64_t host_isar1)
+{
+    CPUState *cs = CPU(cpu);
+    int ret;
+
+    qemu_log("generic-v8: host  ISAR0=0x%016" PRIx64
+             " ISAR1=0x%016" PRIx64 "\n", host_isar0, host_isar1);
+    qemu_log("generic-v8: filt  ISAR0=0x%016" PRIx64
+             " ISAR1=0x%016" PRIx64 "\n",
+             cpu->isar.id_aa64isar0, cpu->isar.id_aa64isar1);
+
+    /* ID_AA64ISAR0_EL1: 3_0_c0_c6_0 */
+    ret = kvm_set_one_reg(cs, ARM64_SYS_REG(3, 0, 0, 6, 0),
+                          &cpu->isar.id_aa64isar0);
+    qemu_log("generic-v8: set ISAR0 -> %s\n",
+             ret == 0 ? "OK" : strerror(-ret));
+
+    /* ID_AA64ISAR1_EL1: 3_0_c0_c6_1 */
+    ret = kvm_set_one_reg(cs, ARM64_SYS_REG(3, 0, 0, 6, 1),
+                          &cpu->isar.id_aa64isar1);
+    qemu_log("generic-v8: set ISAR1 -> %s\n",
+             ret == 0 ? "OK" : strerror(-ret));
+
+    /* ID_AA64ISAR2_EL1: 3_0_c0_c6_2 */
+    ret = kvm_set_one_reg(cs, ARM64_SYS_REG(3, 0, 0, 6, 2),
+                          &cpu->isar.id_aa64isar2);
+    qemu_log("generic-v8: set ISAR2 -> %s\n",
+             ret == 0 ? "OK" : strerror(-ret));
+}
