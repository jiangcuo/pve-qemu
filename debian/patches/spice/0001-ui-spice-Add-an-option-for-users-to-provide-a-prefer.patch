diff --git a/ui/spice-display.c b/ui/spice-display.c
index c794ae0..9073e32 100644
--- a/ui/spice-display.c
+++ b/ui/spice-display.c
@@ -185,7 +185,42 @@ static void qemu_spice_create_one_update(SimpleSpiceDisplay *ssd,
     QTAILQ_INSERT_TAIL(&ssd->updates, update, next);
 }
 
-static void qemu_spice_create_update(SimpleSpiceDisplay *ssd)
+static void qemu_spice_create_update_h264(SimpleSpiceDisplay *ssd)
+{
+    QXLRect fullscreen;
+    int dw, dh;
+
+    if (qemu_spice_rect_is_empty(&ssd->dirty)) {
+        return;
+    }
+
+    dw = ssd->dirty.right - ssd->dirty.left;
+    dh = ssd->dirty.bottom - ssd->dirty.top;
+
+    /* Update mirror with ONLY the dirty pixels (cheap) */
+    pixman_image_composite(PIXMAN_OP_SRC, ssd->surface, NULL, ssd->mirror,
+                           ssd->dirty.left, ssd->dirty.top, 0, 0,
+                           ssd->dirty.left, ssd->dirty.top, dw, dh);
+
+    if (dw * dh >= 96 * 96) {
+        /* Large change: send full screen from mirror for video streaming.
+         * SPICE needs consistent bbox to detect and maintain streams.
+         * The H.264 encoder efficiently skips unchanged macroblocks. */
+        fullscreen.top = 0;
+        fullscreen.left = 0;
+        fullscreen.right = surface_width(ssd->ds);
+        fullscreen.bottom = surface_height(ssd->ds);
+        qemu_spice_create_one_update(ssd, &fullscreen);
+    } else {
+        /* Small change (cursor, clock): send only the dirty rect as bitmap.
+         * Avoids costly full-screen copy + encode for minor updates. */
+        qemu_spice_create_one_update(ssd, &ssd->dirty);
+    }
+
+    memset(&ssd->dirty, 0, sizeof(ssd->dirty));
+}
+
+static void qemu_spice_create_update_default(SimpleSpiceDisplay *ssd)
 {
     static const int blksize = 32;
     int blocks = DIV_ROUND_UP(surface_width(ssd->ds), blksize);
@@ -251,6 +286,15 @@ static void qemu_spice_create_update(SimpleSpiceDisplay *ssd)
     memset(&ssd->dirty, 0, sizeof(ssd->dirty));
 }
 
+static void qemu_spice_create_update(SimpleSpiceDisplay *ssd)
+{
+    if (spice_fullscreen_streaming) {
+        qemu_spice_create_update_h264(ssd);
+    } else {
+        qemu_spice_create_update_default(ssd);
+    }
+}
